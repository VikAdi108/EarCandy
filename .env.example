# AudD Cloud Fallback API Token
# Get a free token (300 requests included) at: https://dashboard.audd.io
# Copy this file to .env and replace the value below.
# If not set, the app falls back to AudD's public sandbox token ('test'), which
# is heavily rate-limited and may return errors.
VITE_AUDD_API_TOKEN=your_audd_api_token_here
